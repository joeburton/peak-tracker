# =============================================================================
# Peak Tracker UK — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to the repository.
#
# Toggle between local MongoDB and Atlas by changing MONGODB_URI only.
# No code changes are required.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Local:  mongodb://localhost:27017/peakTracker
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/peakTracker
MONGODB_URI=mongodb://localhost:27017/peakTracker

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Obtain from https://dashboard.clerk.com — your application's API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect URLs — adjust if you change the auth page routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Peak Tracker UK

# Set to "true" to enable PWA/service worker support.
NEXT_PUBLIC_ENABLE_PWA=true
